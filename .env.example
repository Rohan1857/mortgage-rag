# Provider selection: ollama | openai | openrouter | groq | grok | gemini | huggingface
OCR_PROVIDER=ollama
OCR_MODEL=maternion/LightOnOCR-2:latest
OCR_OUTPUT_MODE = markdown
OCR_API_BASE=
OCR_API_KEY=
OCR_TIMEOUT=120
OCR_SYSTEM_PROMPT=
OCR_USER_PROMPT=Transcribe this page into Markdown only.

EMBED_PROVIDER=ollama
EMBED_MODEL=qwen3-embedding:0.6b
EMBED_API_BASE=
EMBED_API_KEY=

CHAT_PROVIDER=ollama
CHAT_MODEL=qwen2.5:1.5b
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_TEMPERATURE=0
CHAT_NUM_CTX=4096
CHAT_TIMEOUT=300

# Provider-specific keys (used automatically based on provider)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_API_KEY=

XAI_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
