# Google Drive Folder IDs (From your mortgage-rag/common/ structure)
DRIVE_PDF_FOLDER_ID=id_of_the_pdf_folder
DRIVE_DATASET_FOLDER_ID=id_of_the_dataset_folder
DRIVE_RESULTS_ROOT_ID=id_of_the_Results_folder

